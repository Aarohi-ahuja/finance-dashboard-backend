generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  name           String
  role           String   @default("VIEWER")
  status         String   @default("ACTIVE")
  createdRecords Record[] @relation("CreatedRecords")
  updatedRecords Record[] @relation("UpdatedRecords")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Record {
  id          String   @id @default(cuid())
  amount      Float
  type        String
  category    String
  date        DateTime
  description String?

  createdById String?
  createdBy   User?   @relation("CreatedRecords", fields: [createdById], references: [id])

  updatedById String?
  updatedBy   User?   @relation("UpdatedRecords", fields: [updatedById], references: [id])

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
